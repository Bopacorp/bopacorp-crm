    "@biomejs/biome": "^2.5.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "commitlint": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
